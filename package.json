{
  "name": "gaemiguard",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sungblab/GaemiGuard.git"
  },
  "bugs": {
    "url": "https://github.com/Sungblab/GaemiGuard/issues"
  },
  "homepage": "https://github.com/Sungblab/GaemiGuard#readme",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "concurrently -k -n api,desktop \"pnpm --filter @gaemiguard/api dev\" \"pnpm --filter @gaemiguard/desktop dev\"",
    "dev:api": "pnpm --filter @gaemiguard/api dev",
    "dev:desktop": "pnpm --filter @gaemiguard/desktop dev",
    "docs:html": "node scripts/build-docs-html.mjs",
    "verify": "pnpm test && pnpm typecheck && pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  }
}
